<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Eclipse32 OS</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #111; color: #eee; font-family: monospace;
    display: flex; flex-direction: column; align-items: center;
    padding: 20px; min-height: 100vh;
  }
  h1 { font-size: 18px; margin-bottom: 14px; letter-spacing: 2px; color: #aef; }
  #screen_container {
    border: 2px solid #333; background: #000; line-height: 0;
    width: 1024px; height: 768px; position: relative; overflow: hidden;
  }
  #screen_container canvas,
  #screen_container div {
    display: block; position: absolute; top: 0; left: 0;
    width: 1024px !important; height: 768px !important;
  }
  .controls { margin-top: 12px; display: flex; gap: 10px; }
  button {
    font-family: monospace; font-size: 13px; padding: 8px 22px;
    border: 1px solid #555; background: #1e1e1e; color: #eee;
    cursor: pointer; border-radius: 4px;
  }
  button:hover:not(:disabled) { background: #2e2e2e; }
  button:disabled { opacity: 0.4; cursor: default; }
  #status { margin-top: 10px; font-size: 12px; color: #888; text-align: center; max-width: 1024px; }
</style>
</head>
<body>
<h1>Eclipse32 OS</h1>
<div id="screen_container"></div>
<div class="controls">
  <button id="btn-start"  onclick="startVM()">▶ Start</button>
  <button id="btn-pause"  onclick="pauseVM()" disabled>⏸ Pause</button>
  <button id="btn-stop"   onclick="stopVM()"  disabled>■ Stop</button>
</div>
<div id="status">Press Start to boot Eclipse32.</div>

<script src="libv86.js"></script>
<script>
"use strict";
let emulator = null, paused = false;
const statusEl = document.getElementById("status");
function setStatus(msg) { statusEl.textContent = msg; }

function startVM() {
  document.getElementById("btn-start").disabled = true;
  setStatus("Booting…");

  emulator = new V86({
    wasm_path:        "v86.wasm",
    memory_size:      128 * 1024 * 1024,
    vga_memory_size:  8 * 1024 * 1024,
    screen_container: document.getElementById("screen_container"),
    bios:     { url: "bios/seabios.bin" },
    vga_bios: { url: "bios/vgabios.bin" },
    hda:      { url: "eclipse32.img", async: true, size: 33554432 },
    boot_order: 0x2,
    acpi: false,
    autostart: true,
  });

  emulator.add_listener("emulator-ready", function() {
    setStatus("Running — click screen to capture input. Ctrl+Alt to release mouse.");
    document.getElementById("btn-pause").disabled = false;
    document.getElementById("btn-stop").disabled  = false;
  });
}

function pauseVM() {
  if (!emulator) return;
  if (!paused) {
    emulator.stop(); paused = true;
    document.getElementById("btn-pause").textContent = "▶ Resume";
    setStatus("Paused.");
  } else {
    emulator.run(); paused = false;
    document.getElementById("btn-pause").textContent = "⏸ Pause";
    setStatus("Running.");
  }
}

function stopVM() {
  if (!emulator) return;
  emulator.stop(); emulator.destroy(); emulator = null; paused = false;
  document.getElementById("btn-start").disabled  = false;
  document.getElementById("btn-pause").disabled  = true;
  document.getElementById("btn-pause").textContent = "⏸ Pause";
  document.getElementById("btn-stop").disabled   = true;
  setStatus("Stopped. Press Start to reboot.");
}
document.addEventListener("keydown", e => { if (e.key === "Escape" && emulator) stopVM(); });
</script>
</body>
</html>
